// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`01 - Node.js CI with Matrix 1`] = `
{
  "cdkactions_node-ci.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'ci' stack.
name: Node.js CI
on:
  pull_request:
    branches:
      - main
  push:
    branches:
      - main
    paths:
      - .github/workflows/cdkactions_node-ci.yaml
      - src/**
      - package.json
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - id: setup-node
        uses: actions/setup-node@v6
        with:
          node-version: \${{ matrix.nodeVersion }}
      - name: Install
        run: npm ci
      - name: Lint
        run: npm run lint
      - name: Test
        run: npm test
    strategy:
      fail-fast: false
      matrix:
        nodeVersion:
          - "18"
          - "20"
          - "22"
"
,
}
`;

exports[`02 - Docker Build and Push 1`] = `
{
  "cdkactions_docker.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'docker' stack.
concurrency:
  cancel-in-progress: true
  group: docker-\${{ github.ref }}
name: Docker Publish
on:
  push:
    branches:
      - main
    tags:
      - v*
permissions:
  contents: read
  packages: write
jobs:
  push:
    environment:
      name: production
      url: https://ghcr.io
    permissions:
      attestations: write
      contents: read
      id-token: write
      packages: write
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Login to GHCR
        uses: docker/login-action@v3
        with:
          password: \${{ secrets.GITHUB_TOKEN }}
          registry: ghcr.io
          username: \${{ github.actor }}
      - name: Build and push
        uses: docker/build-push-action@v5
        with:
          push: true
          tags: ghcr.io/\${{ github.repository }}:latest
"
,
}
`;

exports[`03 - Multi-Job Pipeline with Dependencies 1`] = `
{
  "cdkactions_pipeline.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'pipeline' stack.
name: Build → Test → Deploy
on:
  push:
    branches:
      - main
jobs:
  build:
    outputs:
      artifact_id: \${{ steps.upload.outputs.artifactId }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Build
        run: npm run build
      - id: upload
        uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/
  deploy:
    environment: production
    if: github.ref == 'refs/heads/main'
    needs:
      - test
    runs-on: ubuntu-latest
    steps:
      - name: Download artifact
        uses: actions/download-artifact@v4
        with:
          name: dist
      - name: Deploy
        run: ./deploy.sh
  notify:
    if: always()
    needs:
      - deploy
    runs-on: ubuntu-latest
    steps:
      - name: Notify
        run: echo "Pipeline finished"
  test:
    needs:
      - build
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Test
        run: npm test
"
,
}
`;

exports[`04 - Scheduled Workflow with Cron 1`] = `
{
  "cdkactions_stale.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'stale' stack.
name: Close Stale Issues
on:
  schedule:
    - cron: 0 0 * * *
      timezone: America/New_York
    - cron: 0 12 * * *
      timezone: America/New_York
jobs:
  stale:
    permissions:
      issues: write
      pull-requests: write
    runs-on: ubuntu-latest
    steps:
      - uses: actions/stale@v9
        with:
          days-before-close: 7
          days-before-stale: 60
          stale-issue-message: This issue is stale.
"
,
}
`;

exports[`05 - Manual Dispatch with Typed Inputs 1`] = `
{
  "cdkactions_deploy-manual.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'deploy' stack.
name: Manual Deploy
on:
  workflow_dispatch:
    inputs:
      concurrency:
        default: "1"
        description: Parallel deploy count
        required: false
        type: number
      dryRun:
        default: false
        description: Dry run only
        required: false
        type: boolean
      environment:
        description: Target environment
        required: true
        type: environment
      logLevel:
        description: Log verbosity
        options:
          - debug
          - info
          - warn
          - error
        required: true
        type: choice
run-name: Deploy by \${{ github.actor }}
jobs:
  deploy:
    if: inputs.logLevel == 'debug'
    runs-on: ubuntu-latest
    steps:
      - name: Deploy
        run: echo "Deploying to \${{ inputs.environment }}"
"
,
}
`;

exports[`06 - Reusable Workflow (workflow_call) 1`] = `
{
  "cdkactions_build-reusable.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'reusable' stack.
name: Reusable Build
on:
  workflow_call:
    inputs:
      nodeVersion:
        description: Node.js version
        required: true
        type: string
      uploadArtifact:
        default: true
        description: Upload build artifact
        required: false
        type: boolean
    outputs:
      buildHash:
        description: SHA of the build output
        value: \${{ jobs.build.outputs.hash }}
    secrets:
      npmToken:
        required: true
      sentryDsn:
        required: false
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Build
        run: npm run build
"
,
  "cdkactions_release.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'reusable' stack.
name: Release
on:
  push:
    tags:
      - v*
jobs:
  call-build:
    secrets: inherit
    uses: ./.github/workflows/cdkactions_build-reusable.yaml
    with:
      nodeVersion: "20"
      uploadArtifact: true
"
,
}
`;

exports[`07 - Container Job with Services 1`] = `
{
  "cdkactions_integration.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'integration' stack.
name: Integration Tests
on:
  push:
    branches:
      - main
jobs:
  integration:
    container:
      env:
        NODE_ENV: test
      image: node:20-bookworm
      options: "--cpus 2"
      volumes:
        - /tmp/cache:/cache
    runs-on: ubuntu-latest
    services:
      postgres:
        env:
          POSTGRES_DB: testdb
          POSTGRES_PASSWORD: test
          POSTGRES_USER: test
        image: postgres:16
        options: "--health-cmd pg_isready --health-interval 10s --health-timeout 5s --health-retries 5"
        ports:
          - 5432:5432
      redis:
        command: redis-server --requirepass testpass
        entrypoint: ""
        image: redis:7
        ports:
          - 6379:6379
    steps:
      - uses: actions/checkout@v4
      - name: Run integration tests
        run: npm run test:integration
"
,
}
`;

