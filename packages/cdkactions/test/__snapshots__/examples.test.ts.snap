exports[`15 - Central Runner Registry 1`] = `
{
  "cdkactions_custom-runners.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'runners' stack.
name: Custom Runners
on:
  push:
    branches:
      - main
jobs:
  build-arm:
    runs-on: ci-arm64
    steps:
      - name: Build
        run: make build ARCH=arm64
  build-x64:
    runs-on: ci-linux-x64
    steps:
      - name: Build
        run: make build
  train:
    runs-on: gpu-a100-80gb
    steps:
      - name: Train model
        run: python train.py
    timeout-minutes: 360
"
,
}
`;

exports[`16 - Typed Action References 1`] = `
{
  "cdkactions_build.yaml": 
"# Generated by cdkactions. Do not modify
# Generated as part of the 'action-refs' stack.
name: Build with Action
on:
  push:
    branches:
      - main
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - id: co
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          lfs: true
      - id: node
        uses: actions/setup-node@v4
        with:
          cache: npm
          node-version: "20"
      - name: Build
        run: npm run build
      - id: upload
        uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/
"
,
}
`;
