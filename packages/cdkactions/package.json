{
  "name": "@factbird/cdkactions",
  "version": "0.0.0",
  "description": "Cloud Development Kit for GitHub Actions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#src/*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "#test/*": "./test/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FactbirdHQ/cdkactions.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "actions",
    "cdk",
    "constructs",
    "github"
  ],
  "peerDependencies": {
    "constructs": "^10.4.2"
  },
  "dependencies": {
    "js-yaml": "^4.0.0",
    "ts-dedent": "^2.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.1.0",
    "constructs": "^10.4.2",
    "typescript": "^5.8.2"
  }
}
