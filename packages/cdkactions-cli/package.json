{
  "name": "@factbird/cdkactions-cli",
  "version": "0.0.0",
  "description": "CDK for GitHub Actions CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cdkactions": "bin/cdkactions"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FactbirdHQ/cdkactions.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "actions",
    "cdk",
    "constructs",
    "github"
  ],
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@factbird/cdkactions": "workspace:^",
    "constructs": "^10.4.2",
    "fs-extra": "^11.3.0",
    "yaml": "^2.7.1",
    "yargs": "^16.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^8.1.0",
    "@types/node": "^22.1.0",
    "@types/yargs": "^17.0.32",
    "typescript": "^5.8.2"
  }
}
