{
  "name": "cdkactions",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/FactbirdHQ/cdkactions.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "clean": "yarn workspaces foreach -A run clean"
  },
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">= 20"
  }
}
